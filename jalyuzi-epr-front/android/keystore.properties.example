# Release imzolash uchun keystore ma'lumotlari namunasi.
# Bu faylni `keystore.properties` deb nusxalang va o'z qiymatlaringizni kiriting.
# `keystore.properties` git'da saqlanmaydi (.gitignore'da).
#
# Keystore yaratish (Android Studio'siz):
#   keytool -genkey -v -keystore D:\Projects\JALYUZI_EPR\jalyuzi-keystore.jks \
#           -alias jalyuzi-epr -keyalg RSA -keysize 2048 -validity 9125
#
# DIQQAT: keystore'ni YO'QOTSANGIZ, ilovani Play Store'da YANGILAB BO'LMAYDI.
# Keystore'ni va bu fayldagi parollarni xavfsiz joyda saqlang.

storeFile=D:\\Projects\\JALYUZI_EPR\\jalyuzi-keystore.jks
storePassword=YOUR_STORE_PASSWORD_HERE
keyAlias=jalyuzi-epr
keyPassword=YOUR_KEY_PASSWORD_HERE
